# On Point Pro Doors CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── SUPABASE ───────────────────────────────────────────────
# Found at: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── GOOGLE SHEETS SYNC (optional) ──────────────────────────
# Deploy the Apps Script from google-sheets/Code.gs as a Web App
# and paste the deployment URL here (configure in Settings > Sync URL)
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
