# On Point Pro Doors CRM — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── SUPABASE ───────────────────────────────────────────────
# Found at: supabase.com → Project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── SUPABASE SERVICE ROLE KEY (Edge Functions only — never in frontend) ─
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── VAPID KEYS (Web Push Notifications) ────────────────────
# Generate: npx web-push generate-vapid-keys
# Set on Supabase: supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=...
VAPID_PUBLIC_KEY=Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_SUBJECT=mailto:admin@onpointdoors.com

# ── SERVER ─────────────────────────────────────────────────
PORT=3000
APP_URL=https://crm.yourdomain.com

# ── GOOGLE SHEETS SYNC (optional) ──────────────────────────
# Deploy the Apps Script from google-sheets/Code.gs as a Web App
# and paste the deployment URL here (configure in Settings > Sync URL)
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
